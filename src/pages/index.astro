---
import PrototypeLayout from "../layouts/PrototypeLayout.astro";
import { createLocalsClient } from "../lib/supabase";
import { shanghaiDateKey } from "../lib/datetime";
import { AUTHOR_LABELS, MOOD_LABELS, asRows } from "../lib/types";
import type { AuthorKey, BlogPost, LifeRecord, Photo, Place, PlaceTone, Profile } from "../lib/types";

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const authorKey = (profile?.author_key || "white") as AuthorKey;
const homeWelcomeName = profile?.display_name || AUTHOR_LABELS[authorKey];

const supabase = createLocalsClient(Astro.locals);

const [
  { data: posts },
  { data: photos },
  { data: placeRows },
  { data: recordRows },
  { data: firstRecordRows },
  { data: firstPostRows },
  { data: firstPhotoRows },
  { data: profileRows },
] = await Promise.all([
  supabase
    .from("blog_posts")
    .select("id,slug,title,excerpt,tags,published_at,created_at,profiles(display_name,author_key)")
    .order("published_at", { ascending: false })
    .limit(3),
  supabase
    .from("photos")
    .select("id,title,caption,taken_on,storage_path,created_at,profiles(display_name,author_key)")
    .order("created_at", { ascending: false })
    .limit(5),
  supabase
    .from("places")
    .select("id,name,note,tone,created_at")
    .order("created_at", { ascending: false })
    .limit(3),
  supabase
    .from("life_records")
    .select("id,record_on,mood,body,created_at,profiles(display_name,author_key)")
    .order("record_on", { ascending: false })
    .order("created_at", { ascending: false })
    .limit(4),
  supabase
    .from("life_records")
    .select("record_on")
    .order("record_on", { ascending: true })
    .limit(1),
  supabase
    .from("blog_posts")
    .select("created_at,published_at")
    .order("created_at", { ascending: true })
    .limit(1),
  supabase
    .from("photos")
    .select("created_at,taken_on")
    .order("created_at", { ascending: true })
    .limit(1),
  supabase
    .from("profiles")
    .select("id,email,author_key,display_name,weather_text,weather_updated_at,mood_text,mood_date,doing_text,doing_date,created_at")
    .in("author_key", ["white", "brown"]),
]);
const dbPlaces = (placeRows || []) as Place[];

const recentPosts = asRows<BlogPost>(posts);
const recentPhotos = asRows<Photo>(photos);
const recentRecords = asRows<LifeRecord>(recordRows);
const displayPhotos = recentPhotos.slice(0, 5);
const homeProfiles = (profileRows || []) as Profile[];
const whiteProfile = homeProfiles.find((p) => p.author_key === "white");
const brownProfile = homeProfiles.find((p) => p.author_key === "brown");
const whiteDisplayName = whiteProfile?.display_name || "White";
const brownDisplayName = brownProfile?.display_name || "Brown";
const whiteWeather = whiteProfile?.weather_text || "";
const brownWeather = brownProfile?.weather_text || "";
const currentWeatherWho = user ? profile?.author_key || "" : "";

// mood / doing 当日才有效，过期就回到默认占位
const todayKey = shanghaiDateKey();
const todayField = (p: Profile | undefined, field: "mood" | "doing") => {
  if (!p) return "";
  const date = field === "mood" ? p.mood_date : p.doing_date;
  const text = field === "mood" ? p.mood_text : p.doing_text;
  return date === todayKey && text ? text : "";
};
const whiteMoodDefault = "Softly happy";
const brownMoodDefault = "Full of energy";
const whiteDoingDefault = "Sorting today's small notes";
const brownDoingDefault = "Planning the next outing";
const whiteMood = todayField(whiteProfile, "mood") || "";
const brownMood = todayField(brownProfile, "mood") || "";
const whiteDoing = todayField(whiteProfile, "doing") || "";
const brownDoing = todayField(brownProfile, "doing") || "";

// 只能编辑自己那一侧；未登录则双方都不可编辑
const canEditWhite = currentWeatherWho === "white";
const canEditBrown = currentWeatherWho === "brown";

const skipCoverOnLoad = Astro.url.searchParams.get("skipCover") === "1";
const homePlaces = dbPlaces.map((p) => ({ name: p.name, note: p.note, tone: p.tone as PlaceTone }));
const formatPostDate = (date: string) => new Date(date).toLocaleDateString("zh-CN").replaceAll("/", ".");

function normalizeDate(value: string | null | undefined) {
  const raw = String(value || "").trim();
  if (!raw) return "";
  if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
  const parsed = new Date(raw);
  if (Number.isNaN(parsed.getTime())) return "";
  return parsed.toISOString().slice(0, 10);
}

function formatMonthDay(value: string) {
  const [yyyy, mm, dd] = value.split("-");
  return `${mm}.${dd}`;
}

function formatFullDate(value: string) {
  const [yyyy, mm, dd] = value.split("-");
  return `${yyyy}.${mm}.${dd}`;
}

function dayCountFrom(value: string) {
  const start = new Date(`${value}T00:00:00Z`);
  const current = new Date(`${todayKey}T00:00:00Z`);
  const delta = Math.floor((current.getTime() - start.getTime()) / 86400000);
  return Math.max(1, delta + 1);
}

function nextDateLabel(value: string) {
  const [, month, day] = value.split("-").map(Number);
  const today = new Date(`${todayKey}T00:00:00Z`);
  let next = new Date(Date.UTC(today.getUTCFullYear(), month - 1, day));
  if (next < today) next = new Date(Date.UTC(today.getUTCFullYear() + 1, month - 1, day));
  const days = Math.round((next.getTime() - today.getTime()) / 86400000);
  if (days === 0) return "Today";
  if (days === 1) return "Tomorrow";
  return `In ${days} days`;
}

type ImportantDate = {
  label: string;
  date: string;
  note: string;
};

function parseImportantDates(raw: string | undefined) {
  if (!raw) return [] as ImportantDate[];
  try {
    const parsed = JSON.parse(raw);
    if (!Array.isArray(parsed)) return [] as ImportantDate[];
    return parsed
      .map((item) => {
        const label = String(item?.label || "").trim();
        const date = normalizeDate(item?.date);
        const note = String(item?.note || "").trim();
        if (!label || !date) return null;
        return { label, date, note };
      })
      .filter(Boolean) as ImportantDate[];
  } catch {
    return [] as ImportantDate[];
  }
}

const configuredLoveStart = normalizeDate(import.meta.env.HOME_LOVE_START_DATE);
const oldestRecordDate = normalizeDate((firstRecordRows?.[0] as { record_on?: string } | undefined)?.record_on);
const oldestPostDate = normalizeDate(
  (firstPostRows?.[0] as { published_at?: string | null; created_at?: string | null } | undefined)?.published_at
  || (firstPostRows?.[0] as { created_at?: string | null } | undefined)?.created_at,
);
const oldestPhotoDate = normalizeDate(
  (firstPhotoRows?.[0] as { taken_on?: string | null; created_at?: string | null } | undefined)?.taken_on
  || (firstPhotoRows?.[0] as { created_at?: string | null } | undefined)?.created_at,
);
const oldestProfileDate = normalizeDate(
  homeProfiles
    .map((item) => item.created_at)
    .filter(Boolean)
    .sort()[0],
);
const spaceStartDate = configuredLoveStart || oldestRecordDate || oldestPostDate || oldestPhotoDate || oldestProfileDate;
const dayCounter = spaceStartDate ? dayCountFrom(spaceStartDate) : 0;
const dayCounterLabel = configuredLoveStart ? "Together days" : "Nest days";
const dayCounterHint = configuredLoveStart ? `Since ${formatFullDate(configuredLoveStart)}` : "Counting from the first saved memory";

const milestoneDates: ImportantDate[] = [
  configuredLoveStart ? { label: "Our day one", date: configuredLoveStart, note: "The start of this little private world." } : null,
  oldestRecordDate ? { label: "First memory", date: oldestRecordDate, note: "The first line kept in Records." } : null,
  oldestPostDate ? { label: "First diary", date: oldestPostDate, note: "The first journal entry in Blog." } : null,
  oldestPhotoDate ? { label: "First photo", date: oldestPhotoDate, note: "The first photo still kept in the wall." } : null,
].filter(Boolean) as ImportantDate[];

const importantDates = (() => {
  const configured = parseImportantDates(import.meta.env.HOME_IMPORTANT_DATES);
  const seen = new Set<string>();
  const merged: ImportantDate[] = [];
  [...configured, ...milestoneDates].forEach((item) => {
    const key = `${item.label}|${item.date}`;
    if (seen.has(key)) return;
    seen.add(key);
    merged.push(item);
  });
  return merged.sort((a, b) => a.date.localeCompare(b.date)).slice(0, 4);
})();

const randomMemoryDeck = [
  ...recentRecords.map((record) => ({
    id: `record-${record.id}`,
    href: "/records",
    kind: "Memory",
    accent: (record.profiles?.author_key || "white") as AuthorKey,
    meta: `${record.profiles?.display_name || AUTHOR_LABELS[(record.profiles?.author_key || "white") as AuthorKey]} · ${MOOD_LABELS[record.mood] || record.mood}`,
    date: record.record_on,
    title: "",
    body: record.body,
    titleFallback: "A note from that day",
    bodyFallback: "Unlock to read this memory.",
  })),
  ...recentPosts.map((post) => ({
    id: `post-${post.id}`,
    href: `/blog/${post.slug}`,
    kind: "Diary",
    accent: (post.profiles?.author_key || "white") as AuthorKey,
    meta: post.profiles?.display_name || "Our Nest",
    date: normalizeDate(post.published_at || post.created_at),
    title: post.title,
    body: post.excerpt || post.title,
    titleFallback: "Private diary",
    bodyFallback: "Unlock to read this diary note.",
  })),
  ...displayPhotos.map((photo) => ({
    id: `photo-${photo.id}`,
    href: "/photos",
    kind: "Photo",
    accent: (photo.profiles?.author_key || "white") as AuthorKey,
    meta: photo.profiles?.display_name || "Our Nest",
    date: normalizeDate(photo.taken_on || photo.created_at),
    title: photo.title || photo.caption || "",
    body: photo.caption || photo.title || "",
    titleFallback: "A saved photo",
    bodyFallback: "Unlock to read the note behind this photo.",
  })),
  ...homePlaces.map((place, index) => ({
    id: `place-${index}`,
    href: "/places",
    kind: "Place",
    accent: place.tone,
    meta: "Wish list",
    date: "",
    title: place.name,
    body: place.note,
    titleFallback: "Locked place",
    bodyFallback: "Unlock to read this place card.",
  })),
].slice(0, 10);
---

<PrototypeLayout
  title="Our Nest"
  current="home"
  htmlClass="home-profile-root"
  bodyClass={skipCoverOnLoad ? "home-profile-page home-revealed" : "home-profile-page home-cover-open"}
  hideNav
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/styles.css" />
    <script is:inline>
      (function () {
        try {
          var params = new URLSearchParams(location.search);
          var hash = (location.hash || "").toLowerCase();
          var skipHome =
            params.get("skipCover") === "1" ||
            hash === "#home" ||
            hash === "#main" ||
            hash === "#skipcover";
          if (skipHome || localStorage.getItem("cuteblog.discoveryIntro.v1") === "1") {
            document.documentElement.classList.add("home-intro-seen");
          }
        } catch (e) {}
      })();
    </script>
  </Fragment>

  <section class="home-discovery" id="homeDiscoveryIntro" aria-label="A quiet note before entering">
    <div class="home-discovery__mist" aria-hidden="true"></div>
    <div class="home-discovery__content" aria-live="polite">
      <p class="home-discovery__line" id="discoveryLineOne"></p>
      <p class="home-discovery__line" id="discoveryLineTwo"></p>
    </div>
  </section>

  <section class="home-cover" id="homeCover" aria-label="Home cover">
    <img class="home-cover__bg" src="/assets/首页封面.webp" alt="" />
    <canvas class="home-cover__petals" id="coverPetals" aria-hidden="true"></canvas>
    <div class="home-cover__shade" aria-hidden="true"></div>
    <div class="home-cover__content">
      <p class="home-cover__eyebrow">Our Nest</p>
      <h1 class="home-cover__title">Welcome to our home</h1>
    </div>
    <button class="home-cover__button" id="exploreHome" type="button" aria-label="Start now">
      <span class="home-cover__button-text home-cover__button-text--top">Explore</span>
      <span class="home-cover__button-text home-cover__button-text--bottom">Start now</span>
    </button>
  </section>

  <div class="home-bg" aria-hidden="true">
    <div class="home-bg__layer" id="homeBg"></div>
    <div class="home-bg__wash"></div>
  </div>

  <header class="site-nav home-nav" data-site-nav>
    <div class="site-nav__bar">
      <a class="site-nav__brand home-nav__brand" href="/?skipCover=1#home">Our Nest</a>
      <nav class="site-nav__links home-nav__links" aria-label="Home navigation">
        <a class="is-active" href="/?skipCover=1#home" aria-current="page">Home</a>
        <a href="/places">Places</a>
        <a href="/blog">Blog</a>
        <a href="/records">Records</a>
        <a href="/photos">Photos</a>
        <a href="/activity">Activity</a>
        <a href="/todo">To Do</a>
        {!user && (
          <a class="site-nav__auth-link" href="/auth/login">Log in</a>
        )}
      </nav>
      {user && (
        <div class="site-nav__auth">
          <form action="/api/auth/logout" method="post">
            <span class={`auth-pill auth-pill--${authorKey}`} title={profile?.display_name || AUTHOR_LABELS[authorKey]}>{profile?.display_name || AUTHOR_LABELS[authorKey]}</span>
            <button class="auth-link" type="submit" aria-label="Log out">Log out</button>
          </form>
        </div>
      )}
    </div>
  </header>

  <main class="home-profile" id="home" data-current-weather-who={currentWeatherWho}>
    <section class="home-hero" aria-labelledby="homeTitle">
      <div class="home-avatar" aria-hidden="true">
        <img class="home-avatar__img" src="/assets/首页头像.webp" alt="" />
      </div>
      <p class="home-kicker">Welcome home, {homeWelcomeName}</p>
      <h1 id="homeTitle">Our Nest</h1>
      <div class="home-presence" aria-live="polite">
        <span id="homeGreeting">A quiet moment for the two of you.</span>
        <time id="homeClock"></time>
      </div>
      <p class="home-hero__text">
        Today’s mood, shared plans, old memories, and all the little things worth keeping close.
      </p>
      <nav class="home-quicklinks" aria-label="Home quick links">
        <a href="/records">Recent memories</a>
        <a href="/photos">Photo wall</a>
        <a href="/blog">Diary</a>
        <a href="/todo">Today plan</a>
        <a href="/places">Wish list</a>
      </nav>
    </section>

    <section class="home-overview" aria-labelledby="overviewTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Private entrance</p>
          <h2 id="overviewTitle">The center of your two-person space</h2>
        </div>
      </div>

      <div class="home-overview__grid">
        <article class="home-summary-card home-summary-card--days">
          <p class="home-summary-card__label">{dayCounterLabel}</p>
          <p class="home-summary-card__value" aria-label={dayCounter ? `${dayCounter} days` : "Day count is waiting for a start date"}>
            {dayCounter ? dayCounter : "..."}
            {dayCounter > 0 && <span class="home-summary-card__unit">days</span>}
          </p>
          <p class="home-summary-card__hint">{dayCounterHint}</p>
        </article>

        <article class="home-summary-card home-summary-card--dates">
          <div class="home-summary-card__top">
            <div>
              <p class="home-summary-card__label">Important dates</p>
              <p class="home-summary-card__hint">A few anchor points you can come back to.</p>
            </div>
          </div>
          <div class="home-date-list">
            {importantDates.length ? importantDates.map((item) => (
              <article class="home-date-item">
                <time datetime={item.date}>{formatMonthDay(item.date)}</time>
                <div>
                  <strong>{item.label}</strong>
                  <span>{item.note}</span>
                  <span class="home-date-item__countdown">{nextDateLabel(item.date)}</span>
                </div>
              </article>
            )) : (
              <p class="home-empty-inline">Your next meaningful date can have a place here.</p>
            )}
          </div>
        </article>

        <section class="home-random" aria-labelledby="randomMemoryTitle">
          <div class="home-random__head">
            <div>
              <p class="home-section-head__kicker">Random pick</p>
              <h3 id="randomMemoryTitle">Random memory card</h3>
            </div>
            <button class="home-random__shuffle" id="homeRandomShuffle" type="button" aria-controls="homeRandomDeck">Shuffle</button>
          </div>
          <div class="home-random__deck" id="homeRandomDeck" aria-live="polite">
            {randomMemoryDeck.length ? randomMemoryDeck.map((item, index) => (
              <a
                class={`home-random-card home-random-card--${item.accent} ${index === 0 ? "is-active" : ""}`}
                href={item.href}
                data-memory-card
              >
                <p class="home-random-card__kind">{item.kind}</p>
                <h4
                  data-private-text={item.title}
                  data-private-fallback={item.titleFallback}
                >{item.titleFallback}</h4>
                <p
                  class="home-random-card__body"
                  data-private-text={item.body}
                  data-private-fallback={item.bodyFallback}
                >{item.bodyFallback}</p>
                <div class="home-random-card__meta">
                  <span>{item.meta}</span>
                  {item.date && <time datetime={item.date}>{formatFullDate(item.date)}</time>}
                </div>
              </a>
            )) : (
              <article class="home-random-card home-random-card--empty is-active">
                <p class="home-random-card__kind">Memory</p>
                <h4>A memory is waiting to happen</h4>
                <p class="home-random-card__body">Add a photo, record, or diary entry and this corner will bring it back to you later.</p>
              </article>
            )}
          </div>
        </section>
      </div>
    </section>

    <section class="home-status-section" aria-labelledby="statusTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Today</p>
          <h2 id="statusTitle">How we are today</h2>
        </div>
      </div>

      <div class="home-duo-status" aria-label="Today status">
        <article class="home-status home-status--white">
          <img class="home-status__dog" src="/assets/小白首页形象.webp" alt={`${whiteDisplayName} avatar`} />
          <div class="home-status__info">
            <h2 data-status-name="white">{whiteDisplayName}</h2>
            <dl>
              <div>
                <dt>Local weather</dt>
                <dd
                  id="whiteWeather"
                  data-server-weather={whiteWeather}
                  data-updated={whiteProfile?.weather_updated_at ?? ""}
                >{"Location pending · Weather pending"}</dd>
              </div>
              <div>
                <dt>Mood</dt>
                <dd class="home-status__editable">
                  <span id="whiteMood" data-server-text={whiteMood}>{whiteMoodDefault}</span>
                  {canEditWhite && (
                    <button class="home-status__edit" type="button" data-who="white" data-field="mood" aria-label={`Edit ${whiteDisplayName}'s mood`}>Edit</button>
                  )}
                </dd>
              </div>
              <div>
                <dt>Doing</dt>
                <dd class="home-status__editable">
                  <span id="whiteDoing" data-server-text={whiteDoing}>{whiteDoingDefault}</span>
                  {canEditWhite && (
                    <button class="home-status__edit" type="button" data-who="white" data-field="doing" aria-label={`Edit what ${whiteDisplayName} is doing`}>Edit</button>
                  )}
                </dd>
              </div>
            </dl>
            <p class="home-status__quote" id="whiteQuote" data-who="white" role="button" tabindex="0" aria-label={`Refresh ${whiteDisplayName}'s note`}>Keep the little things carefully today.</p>
          </div>
        </article>

        <article class="home-status home-status--brown">
          <div class="home-status__info">
            <h2 data-status-name="brown">{brownDisplayName}</h2>
            <dl>
              <div>
                <dt>Local weather</dt>
                <dd
                  id="brownWeather"
                  data-server-weather={brownWeather}
                  data-updated={brownProfile?.weather_updated_at ?? ""}
                >{"Location pending · Weather pending"}</dd>
              </div>
              <div>
                <dt>Mood</dt>
                <dd class="home-status__editable">
                  <span id="brownMood" data-server-text={brownMood}>{brownMoodDefault}</span>
                  {canEditBrown && (
                    <button class="home-status__edit" type="button" data-who="brown" data-field="mood" aria-label={`Edit ${brownDisplayName}'s mood`}>Edit</button>
                  )}
                </dd>
              </div>
              <div>
                <dt>Doing</dt>
                <dd class="home-status__editable">
                  <span id="brownDoing" data-server-text={brownDoing}>{brownDoingDefault}</span>
                  {canEditBrown && (
                    <button class="home-status__edit" type="button" data-who="brown" data-field="doing" aria-label={`Edit what ${brownDisplayName} is doing`}>Edit</button>
                  )}
                </dd>
              </div>
            </dl>
            <p class="home-status__quote" id="brownQuote" data-who="brown" role="button" tabindex="0" aria-label={`Refresh ${brownDisplayName}'s note`}>Write down the places first; the road will appear slowly.</p>
          </div>
          <img class="home-status__dog" src="/assets/小棕首页形象.webp" alt={`${brownDisplayName} avatar`} />
        </article>
      </div>
    </section>

    <section class="home-memories" aria-labelledby="memoriesTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Records</p>
          <h2 id="memoriesTitle">Recent memories</h2>
        </div>
        <a class="home-section-head__link" href="/records">View all</a>
      </div>

      <div class="home-memory-list" id="homeMemoryList">
        {recentRecords.length ? recentRecords.map((record) => {
          const owner = (record.profiles?.author_key || "white") as AuthorKey;
          return (
            <a class={`home-memory-card home-memory-card--${owner}`} href="/records">
              <div class="home-memory-card__top">
                <span>{record.profiles?.display_name || AUTHOR_LABELS[owner]}</span>
                <time datetime={record.record_on}>{formatFullDate(record.record_on)}</time>
              </div>
              <p class="home-memory-card__mood">{MOOD_LABELS[record.mood] || record.mood}</p>
              <p
                class="home-memory-card__body"
                data-private-text={record.body}
                data-private-fallback="Unlock to read this memory."
              >Unlock to read this memory.</p>
            </a>
          );
        }) : (
          <article class="home-empty-card">Waiting for one of you to leave the next little memory.</article>
        )}
      </div>
    </section>

    <section class="home-recent-photos" aria-labelledby="recentPhotosTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Photos</p>
          <h2 id="recentPhotosTitle">Recent photos</h2>
        </div>
        <a class="home-section-head__link" href="/photos">Open wall</a>
      </div>
      <div class="home-photo-stage" id="homeRecentPhotos" aria-live="polite">
        {displayPhotos.length ? displayPhotos.map((photo, index) => (
          <a class="home-photo-card" style={`--i:${index}`} href="/photos">
            <img data-private-photo={`/api/photos/file?id=${encodeURIComponent(photo.id)}`} alt="Private photo" loading="lazy" />
            <span class="home-photo-card__meta">
              <span data-private-text={photo.title || photo.caption || ""} data-private-fallback="A small photo">A small photo</span>
              <small>{photo.taken_on || photo.profiles?.display_name || "Nest"}</small>
            </span>
          </a>
        )) : (
          <div class="home-photo-empty">The photo wall is quiet for now. Your next shared moment belongs here.</div>
        )}
      </div>
    </section>

    <section class="home-posts" aria-labelledby="postsTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Blog</p>
          <h2 id="postsTitle">Recent diary</h2>
        </div>
        <a class="home-section-head__link" href="/blog">Read all</a>
      </div>
      <div class="home-journal-list" id="homeJournalList">
        {recentPosts.length ? recentPosts.map((post) => (
          <a class="home-journal-card" href={`/blog/${post.slug}`}>
            <time datetime={normalizeDate(post.published_at || post.created_at)}>{formatPostDate(post.published_at || post.created_at)}</time>
            <h3 data-private-text={post.title} data-private-fallback="Private diary">Private diary</h3>
            <p data-private-text={post.excerpt || ""} data-private-fallback="Unlock to read the latest diary note.">Unlock to read the latest diary note.</p>
          </a>
        )) : (
          <article class="home-empty-card">No diary entry yet. Leave a few words for the person who knows you best.</article>
        )}
      </div>
    </section>

    <section class="home-places" aria-labelledby="placesTitle">
      <div class="home-section-head">
        <div>
          <p class="home-section-head__kicker">Future list</p>
          <h2 id="placesTitle">Places</h2>
        </div>
        <a class="home-section-head__link" href="/places">View all</a>
      </div>
      <div class="home-places__body">
        <div class="home-places__head">
          <div>
            <p class="home-places__kicker">Places for this year</p>
            <p class="home-places__count" id="placeCount">{homePlaces.length} destinations</p>
          </div>
        </div>

        <div class="place-stage" id="placeList" aria-live="polite">
          {homePlaces.length ? homePlaces.map((place) => (
            <article class={`place-card place-card--${place.tone}`} tabindex="0">
              <div class="place-card__art">
                <span class={place.tone === "night" ? "place-card__moon" : "place-card__sun"}></span>
                <span class="place-card__land"></span>
              </div>
              <div class="place-card__content">
                <h3 class="place-card__name" data-private-text={place.name} data-private-fallback="Locked place"></h3>
                <p class="place-card__note" data-private-text={place.note} data-private-fallback="Unlock to read the note."></p>
              </div>
            </article>
          )) : (
            <article class="home-empty-card">Choose one place you would like to see together someday.</article>
          )}
        </div>
      </div>
    </section>
  </main>

  <div class="status-editor is-hidden" id="statusEditor" role="dialog" aria-modal="true" aria-labelledby="statusEditorTitle">
    <div class="status-editor__mask" data-status-close></div>
    <section class="status-editor__card">
      <button class="status-editor__x" type="button" data-status-close aria-label="Close editor">×</button>
      <p class="status-editor__kicker" id="statusEditorKicker">Today status</p>
      <h2 id="statusEditorTitle">Edit status</h2>
      <p class="status-editor__hint" id="statusEditorHint">Write a short note for today.</p>
      <label class="status-editor__field">
        <span id="statusEditorLabel">Status</span>
        <textarea id="statusEditorInput" maxlength="80" rows="3" placeholder="Type something soft and true."></textarea>
      </label>
      <div class="status-editor__meta">
        <span id="statusEditorCount">0 / 80</span>
        <span id="statusEditorSync">Saved for today</span>
      </div>
      <div class="status-editor__chips" id="statusEditorChips" aria-label="Quick status ideas"></div>
      <div class="status-editor__actions">
        <button class="status-editor__clear" id="statusEditorClear" type="button">Use default</button>
        <span class="status-editor__spacer"></span>
        <button class="status-editor__cancel" type="button" data-status-close>Cancel</button>
        <button class="status-editor__save" id="statusEditorSave" type="button">Save</button>
      </div>
    </section>
  </div>

  <div class="home-feedback" id="homeFeedback" role="status" aria-live="polite" aria-atomic="true"></div>

  <Fragment slot="scripts">
    <script is:inline src="/scripts/cover.js"></script>
    <script is:inline src="/scripts/home.js"></script>
  </Fragment>
</PrototypeLayout>
