---
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import { createLocalsClient } from "../../lib/supabase";
import { authorDisplayName } from "../../lib/author-display";
import { formatCommentTime } from "../../lib/comments-display";
import { shanghaiParts } from "../../lib/datetime";
import type { AuthorKey, BlogPost, Comment } from "../../lib/types";

function safeDecode(value: string) {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
}

const slug = safeDecode(Astro.params.slug || "");
const supabase = createLocalsClient(Astro.locals);
const { data } = await supabase
  .from("blog_posts")
  .select("id,slug,title,excerpt,content_markdown,tags,published_at,created_at,author_id,profiles(display_name,author_key)")
  .eq("slug", slug)
  .maybeSingle();

if (!data) {
  return Astro.redirect("/blog");
}

const post = data as BlogPost;
const author = (post.profiles?.author_key || "white") as AuthorKey;
const authorName = authorDisplayName(post.profiles, author);
const dateValue = post.published_at || post.created_at;
const formatDate = (value: string) => {
  const p = shanghaiParts(value);
  if (!p) return "";
  return `${p.year}.${p.month}.${p.day} ${p.hour}:${p.minute}`;
};
const user = Astro.locals.user;

const { data: commentRows } = await supabase
  .from("comments")
  .select("id,target_type,target_id,author_id,body,created_at,profiles(display_name,author_key)")
  .eq("target_type", "blog")
  .eq("target_id", post.id)
  .order("created_at", { ascending: true });
const comments = (commentRows || []) as Comment[];
const returnTo = `/blog/${encodeURIComponent(post.slug)}`;
const commentError = Astro.url.searchParams.get("error");
---

<PrototypeLayout title={`Blog · Our Nest`} current="blog" bgClass="blog-bg">
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/blog.css" />
    <link rel="stylesheet" href="/styles/comments.css" />
  </Fragment>

  <main class="blog-shell">
    <article class="article">
      <header class="article-head">
        <div class="blog-detail-actions">
          <a class="blog-detail-back" href="/blog" aria-label="Back to blog">Back</a>
          {user?.id === post.author_id && (
            <form class="blog-detail-delete" action="/api/blog/delete" method="post" data-confirm="Remove this diary entry from your shared space? This cannot be undone." data-confirm-title="Remove this diary entry?">
              <input type="hidden" name="id" value={post.id} />
              <input type="hidden" name="return_to" value="/blog" />
              <button type="submit">Delete post</button>
            </form>
          )}
        </div>
        <div class="blog-tags" id="blogTags" aria-label="Post metadata">
          <span class={`blog-tag blog-tag--${author}`}>{authorName}</span>
          <span class="blog-tag">{formatDate(dateValue)}</span>
          <span class="blog-tag" id="blogReadMinutes">Locked</span>
          {(post.tags || []).map((tag) => <span class="blog-tag">{tag}</span>)}
        </div>
        <h1 id="blogTitle" data-private-text={post.title} data-private-fallback="Private post"></h1>
        <p class="article-summary" id="blogExcerpt" data-private-text={post.excerpt || ""} data-private-fallback=""></p>
      </header>

      <div id="blogArticle" data-private-markdown={post.content_markdown}></div>

      <section class="cmt-section" id="comments" aria-label="Comments">
        <p class="cmt-title">Comments · {comments.length}</p>

        {commentError && (
          <p class="site-notice site-notice--error site-notice--block" role="alert">{commentError}</p>
        )}

        {comments.length ? (
          <div class="cmt-list">
            {comments.map((c) => {
              const who = (c.profiles?.author_key || "white") as AuthorKey;
              const name = authorDisplayName(c.profiles, who);
              return (
                <div class={`cmt-row cmt-row--${who}`}>
                  <div class="cmt-meta">
                    <span class="cmt-meta__name">{who === "white" ? "🐶" : "🐕"} {name}</span>
                    <span class="cmt-meta__time">{formatCommentTime(c.created_at)}</span>
                  </div>
                  <div class="cmt-bubble">
                    <span data-private-text={c.body} data-private-fallback="Unlock to read this comment."></span>
                    {user?.id === c.author_id && (
                      <span class="cmt-bubble__delete">
                        <form action="/api/comments/delete" method="post" data-confirm="Delete this comment?" data-confirm-title="Delete comment?">
                          <input type="hidden" name="id" value={c.id} />
                          <input type="hidden" name="return_to" value={returnTo} />
                          <button type="submit" aria-label="Delete comment">Delete</button>
                        </form>
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="cmt-empty">No little notes yet. Leave one for the other person.</p>
        )}

        {user ? (
          <form class="cmt-form" action="/api/comments/create" method="post">
            <input type="hidden" name="target_type" value="blog" />
            <input type="hidden" name="target_id" value={post.id} />
            <input type="hidden" name="return_to" value={returnTo} />
            <textarea name="body" maxlength="500" rows="2" placeholder="Leave a little note for the other person..." required></textarea>
            <button class="cmt-form__send" type="submit">Send</button>
          </form>
        ) : (
          <p class="cmt-login-prompt">
            <a href={`/auth/login?redirect=${encodeURIComponent(returnTo)}`}>Log in</a> to leave a comment.
          </p>
        )}
      </section>
    </article>

    <aside class="toc" aria-label="Table of contents">
      <div class="toc__inner">
        <p class="toc__title">TABLE OF CONTENTS</p>
        <div class="toc__body">
          <span class="toc__track" aria-hidden="true">
            <span class="toc__fill" id="tocFill"></span>
          </span>
          <nav class="toc__list" id="tocList"></nav>
        </div>
      </div>
    </aside>
  </main>

  <Fragment slot="scripts">
    <script>
      import { estimatedReadMinutes, firstMarkdownHeading, markdownToPlainText, renderArticleSections } from "../../lib/markdown";

      const privateSpace = (window as any).OurNestPrivate;
      const article = document.getElementById("blogArticle");
      const title = document.getElementById("blogTitle");
      const excerpt = document.getElementById("blogExcerpt");
      const readMinutes = document.getElementById("blogReadMinutes");

      privateSpace?.ready?.().then(async () => {
        await privateSpace.decryptTextNodes(document.querySelector(".article-head") || document);
        await privateSpace.decryptTextNodes(document.getElementById("comments") || document);
        if (!article) return;
        const encrypted = article.getAttribute("data-private-markdown") || "";
        const markdown = await privateSpace.decryptText(encrypted);
        const sections = renderArticleSections(markdown || "");
        article.innerHTML = sections.map((section) => {
          const heading = section.title !== "Content" ? `<h2>${section.title}</h2>` : "";
          return `<section class="article-section" id="${section.id}" data-toc-title="${section.title}">${heading}${section.html}</section>`;
        }).join("");
        window.dispatchEvent(new CustomEvent("blog:content-ready"));
        if (title && !title.textContent?.trim()) {
          title.textContent = markdownToPlainText(await privateSpace.decryptText(title.getAttribute("data-private-text") || "")) || firstMarkdownHeading(markdown || "") || "Private post";
        }
        if (excerpt) {
          const decryptedExcerpt = await privateSpace.decryptText(excerpt.getAttribute("data-private-text") || "");
          excerpt.textContent = decryptedExcerpt ? markdownToPlainText(decryptedExcerpt) : "";
          excerpt.style.display = excerpt.textContent ? "" : "none";
        }
        if (readMinutes) readMinutes.textContent = `${estimatedReadMinutes(markdown || "")} min read`;
      }).catch(() => {});
    </script>
    <script is:inline src="/scripts/blog.js"></script>
    <script is:inline>
      (function () {
        var privateSpace = window.OurNestPrivate || null;
        document.querySelectorAll(".cmt-form").forEach(function (form) {
          form.addEventListener("submit", function (event) {
            if (!privateSpace || !privateSpace.encryptFormFields) return;
            event.preventDefault();
            privateSpace.encryptFormFields(form, ["body"]).then(function () {
              form.submit();
            }).catch(function () {});
          });
        });
      })();
    </script>
  </Fragment>
</PrototypeLayout>
