---
import PrototypeLayout from "../layouts/PrototypeLayout.astro";
import { createLocalsClient } from "../lib/local-store";
import { shanghaiDateKey } from "../lib/datetime";
import { authorDisplayName, makeAuthorNames } from "../lib/author-display";
import { serializeJsonForScript } from "../lib/security";
import { MOOD_LABELS, asRows } from "../lib/types";
import type { AuthorKey, LifeRecord, Photo } from "../lib/types";

const store = createLocalsClient(Astro.locals);
const user = Astro.locals.user;
const profile = Astro.locals.profile;
const myAuthorKey = (profile?.author_key || "white") as AuthorKey;

const [{ data: photosData }, { data: recordsData }, { data: authorRows }] = await Promise.all([
  store
    .from("photos")
    .select("id,owner_id,title,caption,taken_on,storage_path,mime_type,created_at,profiles(display_name,author_key)")
    .order("taken_on", { ascending: false, nullsFirst: false })
    .order("created_at", { ascending: false }),
  store
    .from("life_records")
    .select("id,owner_id,record_on,mood,body,profiles(display_name,author_key)"),
  store.from("profiles").select("author_key,display_name"),
]);

const photos = asRows<Photo>(photosData);
const records = asRows<LifeRecord>(recordsData);
const authorNames = makeAuthorNames(authorRows || []);
const currentAuthorName = authorDisplayName(profile, myAuthorKey, authorNames);

const recordByKey = new Map<string, LifeRecord>();
records.forEach((r) => {
  const k = `${(r.profiles?.author_key || "white") as AuthorKey}|${r.record_on}`;
  recordByKey.set(k, r);
});

const byDate = new Map<string, typeof photos>();
photos.forEach((p) => {
  const key = p.taken_on || p.created_at.slice(0, 10);
  const list = byDate.get(key) || [];
  list.push(p);
  byDate.set(key, list);
});
const dates = Array.from(byDate.keys()).sort((a, b) => b.localeCompare(a));
const byMonth = new Map<string, string[]>();
dates.forEach((date) => {
  const month = date.slice(0, 7);
  const monthDates = byMonth.get(month) || [];
  monthDates.push(date);
  byMonth.set(month, monthDates);
});
const months = Array.from(byMonth.keys()).sort((a, b) => b.localeCompare(a));

function prettyDate(value: string) {
  const [, mm, dd] = value.split("-");
  return `${Number(mm)}/${Number(dd)}`;
}

function prettyMonth(value: string) {
  const [year, month] = value.split("-");
  return `${year} / ${Number(month)}`;
}

const today = shanghaiDateKey();

// 把详情视图所需的数据序列化，给客户端 JS 使用
const photoBundles: Record<string, Array<{
  id: string;
  url: string;
  title: string | null;
  caption: string | null;
  who: AuthorKey;
  canDelete: boolean;
  diary?: { mood: string; body: string; author: string } | null;
}>> = {};
dates.forEach((date) => {
  photoBundles[date] = (byDate.get(date) || []).map((p) => {
    const who = (p.profiles?.author_key || "white") as AuthorKey;
    const diary = recordByKey.get(`${who}|${date}`);
    return {
      id: p.id,
      url: `/api/photos/file?id=${encodeURIComponent(p.id)}`,
      title: p.title,
      caption: p.caption,
      who,
      canDelete: !!user && p.owner_id === user.id,
      diary: diary ? {
        mood: MOOD_LABELS[diary.mood] || diary.mood,
        body: diary.body,
        author: authorDisplayName(diary.profiles, (diary.profiles?.author_key || "white") as AuthorKey, authorNames),
      } : null,
    };
  });
});

const noticeError = Astro.url.searchParams.get("error");
const uploaded = Astro.url.searchParams.get("uploaded");
const deleted = Astro.url.searchParams.get("deleted");
---

<PrototypeLayout title="Photos · Our Nest" current="photos" bgClass="pw-bg" backHref="/?skipCover=1#home">
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/photos.css" />
  </Fragment>

  <main class="pw-main">
    <section class="pw-wall" id="pwWall">
      <header class="pw-header">
        <h1 class="pw-title">📷 Photos</h1>
        <p class="pw-subtitle">Keeping everyday moments in pictures</p>
        {noticeError && <p class="site-notice site-notice--error" role="alert">{noticeError}</p>}
        {uploaded === "photo" && <p class="site-notice" role="status">This moment is now part of your photo wall.</p>}
        {deleted === "photo" && <p class="site-notice" role="status">The photo has been removed.</p>}
      </header>
      <div class="pw-toolbar">
        {user ? (
          <button class="pw-upload-btn" id="pwUploadBtn" type="button">＋ Upload photo</button>
        ) : (
          <a class="pw-upload-btn" href="/auth/login">Log in to upload</a>
        )}
      </div>
      <div class="pw-group-toggle" role="tablist" aria-label="Group photos">
        <button class="is-active" id="pwMonthToggle" type="button" role="tab" aria-selected="true">By month</button>
        <button id="pwEventToggle" type="button" role="tab" aria-selected="false">By event</button>
      </div>
      <div class="pw-stacks" id="pwStacks">
        {months.length ? months.map((month) => (
          <section class="pw-month" aria-label={`${prettyMonth(month)} photos`}>
            <header class="pw-month__head">
              <h2>{prettyMonth(month)}</h2>
              <span>{(byMonth.get(month) || []).reduce((total, date) => total + (byDate.get(date) || []).length, 0)} photos</span>
            </header>
            <div class="pw-month__stacks">
              {(byMonth.get(month) || []).map((date) => {
          const list = byDate.get(date) || [];
          const preview = list.slice(0, 4);
          const firstAuthor = (list[0]?.profiles?.author_key || "white") as AuthorKey;
          const firstAuthorName = authorDisplayName(list[0]?.profiles, firstAuthor, authorNames);
          return (
            <div class="pw-stack-cell">
              <button class="pw-stack" type="button" data-date={date}>
                {preview.map((photo, idx) => {
                  const rot = (Math.random() * 16 - 8).toFixed(1);
                  const tx = (Math.random() * 14 - 7).toFixed(1);
                  const ty = (Math.random() * 10 - 5).toFixed(1);
                  return (
                    <span class="pw-stack__layer" style={`--rot:${rot}deg;--tx:${tx}px;--ty:${ty}px;z-index:${10 - idx}`}>
                      <img data-private-photo={`/api/photos/file?id=${encodeURIComponent(photo.id)}`} alt="Private photo" loading="lazy" />
                    </span>
                  );
                })}
                <span class="pw-stack__count">{list.length} photos</span>
              </button>
              <div class="pw-stack__meta">
                <div class="pw-stack__name">{prettyDate(date)}</div>
                <div class="pw-stack__sub">{firstAuthorName} · {list.length} photos</div>
              </div>
            </div>
          );
              })}
            </div>
          </section>
        )) : <div class="pw-empty">No photos yet. Upload the first one above.</div>}
      </div>
      <div class="pw-event-groups is-hidden" id="pwEventGroups" aria-live="polite"></div>
    </section>

    <p class="pw-private-notice is-hidden" id="pwPrivateNotice" role="status" aria-live="polite">
      <span id="pwPrivateNoticeText"></span>
      <button id="pwPrivateRetry" type="button">Try again</button>
    </p>

    <section class="pw-detail is-hidden" id="pwDetail">
      <div class="pw-detail__bar">
        <button class="pw-back-btn" id="pwBackBtn" type="button">← Photos</button>
        <div class="pw-detail__meta">
          <span class="pw-detail__date" id="pwDetailDate"></span>
          <span class="pw-detail__count" id="pwDetailCount"></span>
        </div>
      </div>
      <div class="pw-grid" id="pwGrid"></div>
    </section>
  </main>

  {user && (
    <div class="pw-modal is-hidden" id="pwModal" role="dialog" aria-modal="true" aria-label="Upload photo">
      <div class="pw-modal__mask" id="pwModalMask"></div>
      <form class="pw-modal__card" id="pwUploadForm" action="/api/photos/upload" method="post" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="return_to" value="/photos" />
        <h2 class="pw-modal__title">Upload photo</h2>
        <div class="pw-field">
          <span class="pw-field__label">Uploader</span>
          <div class="pw-who" aria-label={`Current account: ${currentAuthorName}`}>
            <span class={`pw-who__btn ${myAuthorKey === "white" ? "is-active" : ""}`}>🐶 {authorNames.white}</span>
            <span class={`pw-who__btn ${myAuthorKey === "brown" ? "is-active" : ""}`}>🐕 {authorNames.brown}</span>
          </div>
        </div>
        <div class="pw-field">
          <span class="pw-field__label">Date</span>
          <input class="pw-date" name="taken_on" type="date" value={today} />
        </div>
        <div class="pw-field">
          <span class="pw-field__label">Moment / event name (optional)</span>
          <input class="pw-date" name="title" type="text" maxlength="80" placeholder="e.g. Weekend walk" />
        </div>
        <label class="pw-filebtn">
          ＋ Choose photo
          <input type="file" name="photo" accept="image/jpeg,image/png,image/webp,image/gif" required hidden />
        </label>
        <p class="pw-modal__status" id="pwStatus" role="status" aria-live="polite"></p>
        <div class="pw-modal__actions">
          <button class="pw-modal__close" id="pwModalClose" type="button">Cancel</button>
          <button class="pw-modal__close pw-modal__save" type="submit">Save</button>
        </div>
      </form>
    </div>
  )}

  <div class="pw-lb is-hidden" id="pwLb" role="dialog" aria-modal="true" aria-label="View photo">
    <button class="pw-lb__close" id="pwLbClose" type="button" aria-label="Close">✕</button>
    <button class="pw-lb__nav pw-lb__nav--prev" id="pwLbPrev" type="button" aria-label="Previous photo">‹</button>
    <button class="pw-lb__nav pw-lb__nav--next" id="pwLbNext" type="button" aria-label="Next photo">›</button>
    <figure class="pw-lb__stage">
      <img class="pw-lb__img" id="pwLbImg" alt="" />
      <figcaption class="pw-lb__cap" id="pwLbCap"></figcaption>
      <div class="pw-lb__diary is-hidden" id="pwLbDiary"></div>
      <button class="pw-lb__retry is-hidden" id="pwLbRetry" type="button">Try photo again</button>
    </figure>
    {user && (
      <form class="pw-lb__delete-form is-hidden" id="pwLbDeleteForm" action="/api/photos/delete" method="post" data-confirm="Delete this photo? This cannot be undone." data-confirm-title="Delete photo?">
        <input type="hidden" name="id" id="pwLbDeleteId" value="" />
        <input type="hidden" name="return_to" value="/photos" />
        <button class="pw-lb__delete" type="submit">Delete photo</button>
      </form>
    )}
  </div>

  <script id="photoBundles" type="application/json" set:html={serializeJsonForScript(photoBundles)}></script>
  {user && (
    <script>
      import { uploadImageFile } from "../lib/upload-browser";

      const form = document.getElementById("pwUploadForm") as HTMLFormElement | null;
      const status = document.getElementById("pwStatus");
      if (form) {
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const fileInput = form.querySelector('input[name="photo"]') as HTMLInputElement | null;
        fileInput?.addEventListener("change", () => {
          const file = fileInput.files?.[0];
          if (status) status.textContent = file ? `Selected ${file.name}` : "";
        });
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const file = fileInput?.files?.[0];
          if (!file) {
            if (status) status.textContent = "Please choose a photo to upload.";
            return;
          }

          const title = (form.querySelector('input[name="title"]') as HTMLInputElement | null)?.value.trim() || "";
          const takenOn = (form.querySelector('input[name="taken_on"]') as HTMLInputElement | null)?.value.trim() || "";

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.setAttribute("aria-busy", "true");
          }
          if (status) status.textContent = "Uploading…";

          try {
            const privateSpace = (window as any).OurNestPrivate;
            if (!privateSpace?.encryptText) throw new Error("Private-space encryption is not ready.");
            const encryptedTitle = title ? await privateSpace.encryptText(title, "photo.title") : "";
            const { path, mime_type } = await uploadImageFile(file);
            const res = await fetch("/api/photos/commit", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ path, mime_type, title: encryptedTitle, taken_on: takenOn }),
            });
            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              throw new Error(data.error || "Could not save the photo.");
            }
            window.location.href = "/photos?uploaded=photo";
          } catch (err) {
            if (status) status.textContent = err instanceof Error ? err.message : "Upload failed.";
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.removeAttribute("aria-busy");
            }
          }
        });
      }
    </script>
  )}

  <Fragment slot="scripts">
    <script is:inline>
      (function () {
        "use strict";
        var bundles = {};
        try { bundles = JSON.parse(document.getElementById("photoBundles").textContent || "{}"); } catch (e) {}
        var privateSpace = window.OurNestPrivate || null;
        var privateNotice = document.getElementById("pwPrivateNotice");
        var privateNoticeText = document.getElementById("pwPrivateNoticeText");
        var privateRetry = document.getElementById("pwPrivateRetry");

        var wallEl = document.getElementById("pwWall");
        var detailEl = document.getElementById("pwDetail");
        var gridEl = document.getElementById("pwGrid");
        var detailDate = document.getElementById("pwDetailDate");
        var detailCount = document.getElementById("pwDetailCount");
        var backBtn = document.getElementById("pwBackBtn");
        var stacksEl = document.getElementById("pwStacks");
        var eventGroupsEl = document.getElementById("pwEventGroups");
        var monthToggle = document.getElementById("pwMonthToggle");
        var eventToggle = document.getElementById("pwEventToggle");
        var detailReturnFocus = null;
        var eventBuildPromise = null;

        function activePhotoScope() {
          return detailEl && !detailEl.classList.contains("is-hidden") ? gridEl : wallEl;
        }

        function updatePrivateNotice() {
          if (!privateNotice || !privateNoticeText) return;
          var scope = activePhotoScope();
          var failedPhotos = scope ? scope.querySelectorAll('[data-private-photo][data-private-loaded="error"]') : [];
          if (!failedPhotos.length) {
            privateNotice.classList.add("is-hidden");
            return;
          }
          var networkError = Array.prototype.some.call(failedPhotos, function (node) {
            return /load the encrypted photo|failed to fetch|network/i.test(node.getAttribute("data-private-error") || "");
          });
          privateNoticeText.textContent = networkError
            ? "Some photos could not download. Check your connection, then try again."
            : "Some photos could not be decrypted. Refresh or unlock the private space again, then try once more.";
          privateNotice.classList.remove("is-hidden");
        }

        function hydratePhotos(scope) {
          if (!privateSpace || !privateSpace.ready || !scope) return Promise.reject(new Error("Private space is unavailable."));
          return privateSpace.ready().then(function () {
            return privateSpace.hydratePhotoNodes(scope);
          }).then(updatePrivateNotice);
        }

        if (privateRetry) {
          privateRetry.addEventListener("click", function () {
            privateRetry.disabled = true;
            privateRetry.textContent = "Trying…";
            hydratePhotos(activePhotoScope()).catch(function () {
              if (privateNotice && privateNoticeText) {
                privateNoticeText.textContent = "Private space is not ready yet. Unlock it, then try again.";
                privateNotice.classList.remove("is-hidden");
              }
            }).finally(function () {
              privateRetry.disabled = false;
              privateRetry.textContent = "Try again";
            });
          });
        }

        function prettyDate(s) {
          var p = s.split("-");
          return Number(p[1]) + "/" + Number(p[2]);
        }

        function eventLabel(value) {
          var label = String(value || "").replace(/\s+/g, " ").trim();
          if (!label || /^\[Encrypted content (unavailable|needs migration)\]$/.test(label)) return "Everyday moments";
          return label;
        }

        function setGroupView(view) {
          var showEvents = view === "event";
          if (stacksEl) stacksEl.classList.toggle("is-hidden", showEvents);
          if (eventGroupsEl) eventGroupsEl.classList.toggle("is-hidden", !showEvents);
          if (monthToggle) {
            monthToggle.classList.toggle("is-active", !showEvents);
            monthToggle.setAttribute("aria-selected", String(!showEvents));
          }
          if (eventToggle) {
            eventToggle.classList.toggle("is-active", showEvents);
            eventToggle.setAttribute("aria-selected", String(showEvents));
          }
          if (showEvents) buildEventGroups().catch(function () {});
        }

        function buildEventGroups() {
          if (eventBuildPromise) return eventBuildPromise;
          if (!eventGroupsEl || !privateSpace || !privateSpace.ready || !privateSpace.decryptText) {
            if (eventGroupsEl) eventGroupsEl.textContent = "Unlock the private space to group photos by event.";
            return Promise.reject(new Error("Private space is unavailable."));
          }
          eventGroupsEl.textContent = "Unlocking event names…";
          var entries = [];
          Object.keys(bundles).forEach(function (date) {
            (bundles[date] || []).forEach(function (item) {
              entries.push({ date: date, item: item });
            });
          });
          eventBuildPromise = privateSpace.ready().then(function () {
            return Promise.all(entries.map(function (entry) {
              return privateSpace.decryptText(entry.item.title || "", "photo.title").then(function (title) {
                return { date: entry.date, item: entry.item, label: eventLabel(title) };
              });
            }));
          }).then(function (eventPhotos) {
            var groups = new Map();
            eventPhotos.forEach(function (entry) {
              var key = entry.label.toLocaleLowerCase();
              var group = groups.get(key) || { label: entry.label, items: [] };
              group.items.push(entry.item);
              groups.set(key, group);
            });
            eventGroupsEl.textContent = "";
            if (!groups.size) {
              var empty = document.createElement("p");
              empty.className = "pw-event-empty";
              empty.textContent = "No photos have been saved yet.";
              eventGroupsEl.appendChild(empty);
              return;
            }
            groups.forEach(function (group) {
              var card = document.createElement("button");
              card.type = "button";
              card.className = "pw-event-card";
              var preview = document.createElement("img");
              preview.className = "pw-event-card__photo";
              preview.alt = "Private photo";
              preview.loading = "lazy";
              preview.setAttribute("data-private-photo", group.items[0].url);
              var meta = document.createElement("span");
              var name = document.createElement("span");
              name.className = "pw-event-card__name";
              name.textContent = group.label;
              var count = document.createElement("span");
              count.className = "pw-event-card__count";
              count.textContent = group.items.length + (group.items.length === 1 ? " photo" : " photos");
              meta.appendChild(name);
              meta.appendChild(count);
              card.appendChild(preview);
              card.appendChild(meta);
              card.addEventListener("click", function () { openPhotoList(group.label, group.items); });
              eventGroupsEl.appendChild(card);
            });
            return hydratePhotos(eventGroupsEl);
          }).catch(function (error) {
            eventBuildPromise = null;
            eventGroupsEl.textContent = "Event names could not be unlocked. Refresh or unlock the private space again, then retry.";
            throw error;
          });
          return eventBuildPromise;
        }

        if (monthToggle) monthToggle.addEventListener("click", function () { setGroupView("month"); });
        if (eventToggle) eventToggle.addEventListener("click", function () { setGroupView("event"); });

        function openDetail(date) {
          var list = bundles[date] || [];
          openPhotoList(prettyDate(date), list);
        }

        function openPhotoList(label, list) {
          if (!list.length) return;
          detailReturnFocus = document.activeElement;
          detailDate.textContent = label;
          detailCount.textContent = list.length + " photos";
          gridEl.textContent = "";
          list.forEach(function (item, idx) {
            var wrap = document.createElement("div");
            wrap.className = "pw-photo-wrap";
            var card = document.createElement("button");
            card.type = "button";
            card.className = "pw-photo-card";
            card.setAttribute("data-idx", idx);
            var img = document.createElement("img");
            img.alt = "Private photo";
            img.loading = "lazy";
            img.setAttribute("data-private-photo", item.url);
            card.appendChild(img);
            card.addEventListener("click", function () { openLbList(list, idx); });
            wrap.appendChild(card);
            if (item.canDelete) {
              var form = document.createElement("form");
              form.className = "pw-photo-delete";
              form.action = "/api/photos/delete";
              form.method = "post";
              form.setAttribute("data-confirm", "Delete this photo? This cannot be undone.");
              form.setAttribute("data-confirm-title", "Delete photo?");
              var id = document.createElement("input");
              id.type = "hidden";
              id.name = "id";
              id.value = item.id;
              var ret = document.createElement("input");
              ret.type = "hidden";
              ret.name = "return_to";
              ret.value = "/photos";
              var del = document.createElement("button");
              del.type = "submit";
              del.className = "pw-photo-delete__btn";
              del.setAttribute("aria-label", "Delete photo");
              del.textContent = "×";
              form.appendChild(id);
              form.appendChild(ret);
              form.appendChild(del);
              wrap.appendChild(form);
            }
            gridEl.appendChild(wrap);
          });
          wallEl.classList.add("is-hidden");
          detailEl.classList.remove("is-hidden");
          hydratePhotos(gridEl).catch(function () {});
          window.scrollTo({ top: 0, behavior: "smooth" });
          if (backBtn) window.setTimeout(function () { backBtn.focus(); }, 0);
        }

        function closeDetail() {
          detailEl.classList.add("is-hidden");
          wallEl.classList.remove("is-hidden");
          updatePrivateNotice();
          if (detailReturnFocus && detailReturnFocus.focus) detailReturnFocus.focus();
        }

        document.querySelectorAll(".pw-stack").forEach(function (btn) {
          btn.addEventListener("click", function () {
            openDetail(btn.getAttribute("data-date"));
          });
        });
        if (backBtn) backBtn.addEventListener("click", closeDetail);

        // 上传模态
        var modal = document.getElementById("pwModal");
        var uploadBtn = document.getElementById("pwUploadBtn");
        var modalMask = document.getElementById("pwModalMask");
        var modalClose = document.getElementById("pwModalClose");
        var dialogReturnFocus = null;
        function updateDialogLock() {
          var modalOpen = modal && !modal.classList.contains("is-hidden");
          var lbOpen = lbEl && !lbEl.classList.contains("is-hidden");
          document.documentElement.classList.toggle("has-open-dialog", !!(modalOpen || lbOpen));
        }
        function openModal() {
          if (!modal) return;
          dialogReturnFocus = document.activeElement;
          modal.classList.remove("is-hidden");
          updateDialogLock();
          window.setTimeout(function () {
            var firstField = modal.querySelector("input:not([type='hidden'])");
            (firstField || modalClose).focus();
          }, 0);
        }
        function closeModal() {
          if (!modal) return;
          modal.classList.add("is-hidden");
          updateDialogLock();
          if (dialogReturnFocus && dialogReturnFocus.focus) dialogReturnFocus.focus();
        }
        if (uploadBtn) uploadBtn.addEventListener("click", openModal);
        if (modalMask) modalMask.addEventListener("click", closeModal);
        if (modalClose) modalClose.addEventListener("click", closeModal);
        hydratePhotos(wallEl).catch(function () {
          if (privateNotice && privateNoticeText) {
            privateNoticeText.textContent = "Private space is not ready yet. Unlock it, then try again.";
            privateNotice.classList.remove("is-hidden");
          }
        });

        // 灯箱 + slicebox 翻转
        var lbEl = document.getElementById("pwLb");
        var lbImg = document.getElementById("pwLbImg");
        var lbCap = document.getElementById("pwLbCap");
        var lbDiary = document.getElementById("pwLbDiary");
        var lbPrev = document.getElementById("pwLbPrev");
        var lbNext = document.getElementById("pwLbNext");
        var lbRetry = document.getElementById("pwLbRetry");
        var lbDeleteForm = document.getElementById("pwLbDeleteForm");
        var lbDeleteId = document.getElementById("pwLbDeleteId");
        var lbList = [], lbIndex = 0;
        var lbReturnFocus = null;
        var lbRenderToken = 0;

        var SLICE_EASE = "cubic-bezier(0.66, 0.02, 0.34, 1)";
        var SHADE_MAX = "0.6";
        var sliceBusy = false;
        var pendingSlide = null;
        var lbGen = 0;
        var lbFlipIdx = 0;

        function escapeHtml(s) {
          return (s || "").replace(/[<>&]/g, function (c) { return ({"<":"&lt;",">":"&gt;","&":"&amp;"})[c]; });
        }

        function renderLbMeta(item, token) {
          if (lbDeleteForm && lbDeleteId) {
            lbDeleteForm.classList.toggle("is-hidden", !item.canDelete);
            lbDeleteId.value = item.canDelete ? item.id : "";
          }
          Promise.all([
            privateSpace && privateSpace.decryptText ? privateSpace.decryptText(item.title || "", "photo.title") : Promise.resolve(item.title || ""),
            privateSpace && privateSpace.decryptText ? privateSpace.decryptText(item.caption || "", "photo.caption") : Promise.resolve(item.caption || ""),
            item.diary && privateSpace && privateSpace.decryptText ? privateSpace.decryptText(item.diary.body || "", "record.body") : Promise.resolve(item.diary && item.diary.body || ""),
          ]).then(function (values) {
            if (token !== lbRenderToken) return;
            if (values.some(function (value) { return /^\[Encrypted content (unavailable|needs migration)\]$/.test(value); })) {
              lbCap.textContent = "A private caption could not be unlocked. Refresh or unlock the private space again, then retry.";
              lbDiary.classList.add("is-hidden");
              lbDiary.textContent = "";
              if (lbRetry) lbRetry.classList.remove("is-hidden");
              return;
            }
            lbCap.textContent = values[0] || values[1] || "";
            if (item.diary) {
              lbDiary.classList.remove("is-hidden");
              lbDiary.innerHTML = '<div class="pw-lb__diary-head">' + escapeHtml(item.diary.author) + ' · ' + escapeHtml(item.diary.mood) + '</div><div class="pw-lb__diary-text">' + escapeHtml(values[2]) + '</div>';
            } else {
              lbDiary.classList.add("is-hidden");
              lbDiary.innerHTML = "";
            }
          }).catch(function () {
            if (token !== lbRenderToken) return;
            lbCap.textContent = "A private caption could not be unlocked. Refresh or unlock the private space again, then retry.";
            lbDiary.classList.add("is-hidden");
            lbDiary.textContent = "";
            if (lbRetry) lbRetry.classList.remove("is-hidden");
          });
        }

        function showLb() {
          var item = lbList[lbIndex];
          if (!item) return;
          var token = ++lbRenderToken;
          lbImg.removeAttribute("src");
          lbImg.setAttribute("data-private-loaded", "");
          lbImg.style.visibility = "";
          lbCap.textContent = "Loading private photo…";
          lbDiary.classList.add("is-hidden");
          lbDiary.textContent = "";
          if (lbRetry) lbRetry.classList.add("is-hidden");
          if (privateSpace && privateSpace.hydratePhotoNodes) {
            lbImg.setAttribute("data-private-photo", item.url);
            privateSpace.hydratePhotoNodes(lbEl).then(function () {
              if (token !== lbRenderToken) return;
              if (lbImg.getAttribute("data-private-loaded") === "error") {
                var failedToDownload = /load the encrypted photo|failed to fetch|network/i.test(lbImg.getAttribute("data-private-error") || "");
                lbCap.textContent = failedToDownload
                  ? "The encrypted photo could not download. Check your connection and retry."
                  : "This photo could not be decrypted. Refresh or unlock the private space again, then retry.";
                if (lbRetry) lbRetry.classList.remove("is-hidden");
                return;
              }
              lbImg.style.visibility = "";
              renderLbMeta(item, token);
            }).catch(function () {
              if (token === lbRenderToken) {
                lbCap.textContent = "This private photo could not be opened. Check your connection and retry.";
                if (lbRetry) lbRetry.classList.remove("is-hidden");
              }
            });
          } else {
            lbCap.textContent = "Private space is unavailable. Refresh and unlock it again, then retry.";
            if (lbRetry) lbRetry.classList.remove("is-hidden");
          }
        }

        function openLbList(list, idx) {
          lbReturnFocus = document.activeElement;
          lbList = list || [];
          if (!lbList.length) return;
          lbIndex = idx;
          lbGen++;
          sliceBusy = false;
          showLb();
          var many = lbList.length > 1;
          lbPrev.style.display = many ? "" : "none";
          lbNext.style.display = many ? "" : "none";
          lbEl.classList.remove("is-hidden");
          updateDialogLock();
          window.setTimeout(function () { document.getElementById("pwLbClose").focus(); }, 0);
          document.addEventListener("keydown", lbKey);
        }
        function closeLb() {
          if (pendingSlide) pendingSlide.finish();
          lbGen++;
          sliceBusy = false;
          lbEl.classList.add("is-hidden");
          updateDialogLock();
          if (lbDeleteForm && lbDeleteId) {
            lbDeleteForm.classList.add("is-hidden");
            lbDeleteId.value = "";
          }
          document.removeEventListener("keydown", lbKey);
          if (lbReturnFocus && lbReturnFocus.focus) lbReturnFocus.focus();
        }
        function prefersReducedMotion() {
          return !!(window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches);
        }
        function lbStep(d) {
          if (lbList.length < 2 || sliceBusy) return;
          var nextIndex = (lbIndex + d + lbList.length) % lbList.length;
          lbIndex = nextIndex;
          showLb();
        }
        function lbKey(e) {
          if (e.key === "Escape") closeLb();
          else if (e.key === "ArrowLeft") lbStep(-1);
          else if (e.key === "ArrowRight") lbStep(1);
        }

        function sliceTransition(nextIndex, forward) {
          var toPhoto = lbList[nextIndex];
          if (!toPhoto) return;
          var rect = lbImg.getBoundingClientRect();
          if (rect.width < 8 || rect.height < 8) {
            lbIndex = nextIndex;
            showLb();
            return;
          }
          sliceBusy = true;
          var whole = (lbFlipIdx % 2) === 1;
          lbFlipIdx++;
          var gen = lbGen;
          var fromUrl = lbImg.src;
          var toUrl = toPhoto.url;
          var pre = new Image();
          pre.onload = function () {
            if (gen !== lbGen) return;
            runSlice(rect, fromUrl, toUrl,
                     pre.naturalWidth || rect.width,
                     pre.naturalHeight || rect.height,
                     nextIndex, forward, whole);
          };
          pre.onerror = function () {
            sliceBusy = false;
            if (gen !== lbGen) return;
            lbIndex = nextIndex;
            showLb();
          };
          pre.src = toUrl;
        }

        function makeFace(url, bgSize, bgPos, transform, dur, delay, shade0) {
          var face = document.createElement("div");
          face.className = "pw-slice__face";
          face.style.backgroundImage = "url(" + url + ")";
          face.style.backgroundSize = bgSize;
          face.style.backgroundPosition = bgPos;
          face.style.transform = transform;
          var shade = document.createElement("div");
          shade.className = "pw-slice__shade";
          shade.style.opacity = shade0;
          shade.style.transition = "opacity " + dur + "ms " + SLICE_EASE;
          shade.style.transitionDelay = delay;
          face.appendChild(shade);
          return { face: face, shade: shade };
        }

        function runSlice(rect, fromUrl, toUrl, nW, nH, nextIndex, forward, whole) {
          var W = rect.width, H = rect.height;
          var vertical = Math.random() < 0.5;
          var N = whole ? 1 : (3 + Math.floor(Math.random() * 6));
          var step = whole ? 0 : Math.max(55, Math.min(95, Math.round(440 / N)));
          var reverse = Math.random() < 0.5;
          var dur = whole ? 780 : 660;
          var seam = whole ? 0 : 1;
          var rotAxis = vertical ? "Y" : "X";

          var wrapFlip = forward ? (vertical ? -90 : 90) : (vertical ? 90 : -90);
          var sideAngle = -wrapFlip;

          var unit = (vertical ? W : H) / N;
          var depth = unit + seam;
          var half = depth / 2;

          var persp = Math.max(1500, half * 2.6);
          var f = persp / (persp - half);

          var box = document.createElement("div");
          box.className = "pw-slicebox";
          box.style.left = rect.left + "px";
          box.style.top = rect.top + "px";
          box.style.width = W + "px";
          box.style.height = H + "px";
          box.style.perspective = persp + "px";
          box.style.transform = "scale(" + (1 / f) + ")";

          var cover = Math.max(W / nW, H / nH);
          var drawW = nW * cover, drawH = nH * cover;
          var offX = (W - drawW) / 2, offY = (H - drawH) / 2;

          var slices = [];
          for (var i = 0; i < N; i++) {
            var slice = document.createElement("div");
            slice.className = "pw-slice";
            if (vertical) {
              slice.style.left = (i * unit) + "px";
              slice.style.top = "0";
              slice.style.width = depth + "px";
              slice.style.height = H + "px";
            } else {
              slice.style.left = "0";
              slice.style.top = (i * unit) + "px";
              slice.style.width = W + "px";
              slice.style.height = depth + "px";
            }
            slice.style.transform = "rotate" + rotAxis + "(0deg)";
            slice.style.transition = "transform " + dur + "ms " + SLICE_EASE;
            var delay = ((reverse ? (N - 1 - i) : i) * step) + "ms";
            slice.style.transitionDelay = delay;

            var front = makeFace(fromUrl, W + "px " + H + "px",
              vertical ? (-(i * unit)) + "px 0px" : "0px " + (-(i * unit)) + "px",
              "translateZ(" + half + "px)", dur, delay, "0");
            var side = makeFace(toUrl, drawW + "px " + drawH + "px",
              vertical ? (offX - i * unit) + "px " + offY + "px"
                       : offX + "px " + (offY - i * unit) + "px",
              "rotate" + rotAxis + "(" + sideAngle + "deg) translateZ(" + half + "px)",
              dur, delay, SHADE_MAX);

            slice.appendChild(front.face);
            slice.appendChild(side.face);
            box.appendChild(slice);
            slices.push({ el: slice, frontShade: front.shade, sideShade: side.shade });
          }

          lbEl.appendChild(box);
          lbImg.style.visibility = "hidden";
          void box.offsetWidth;

          requestAnimationFrame(function () {
            slices.forEach(function (s) {
              s.el.style.transform = "rotate" + rotAxis + "(" + wrapFlip + "deg)";
              s.frontShade.style.opacity = SHADE_MAX;
              s.sideShade.style.opacity = "0";
            });
          });

          function finish() {
            if (!pendingSlide) return;
            clearTimeout(pendingSlide.timer);
            pendingSlide = null;
            if (box.parentNode) box.parentNode.removeChild(box);
            lbIndex = nextIndex;
            lbImg.src = toUrl;
            lbImg.style.visibility = "";
            var p = lbList[lbIndex];
            if (p) renderLbMeta(p, ++lbRenderToken);
            sliceBusy = false;
          }

          pendingSlide = {
            finish: finish,
            timer: setTimeout(finish, (N - 1) * step + dur + 90)
          };
        }

        document.getElementById("pwLbClose").addEventListener("click", closeLb);
        lbPrev.addEventListener("click", function () { lbStep(-1); });
        lbNext.addEventListener("click", function () { lbStep(1); });
        if (lbRetry) lbRetry.addEventListener("click", showLb);
        lbEl.addEventListener("click", function (e) { if (e.target === lbEl) closeLb(); });
        var swipeStart = null;
        lbEl.addEventListener("pointerdown", function (event) {
          if (event.pointerType !== "touch" || !event.target.closest(".pw-lb__stage")) return;
          swipeStart = { x: event.clientX, y: event.clientY };
        });
        lbEl.addEventListener("pointerup", function (event) {
          if (!swipeStart || event.pointerType !== "touch") return;
          var deltaX = event.clientX - swipeStart.x;
          var deltaY = event.clientY - swipeStart.y;
          swipeStart = null;
          if (Math.abs(deltaX) < 48 || Math.abs(deltaX) <= Math.abs(deltaY)) return;
          lbStep(deltaX < 0 ? 1 : -1);
        });
        lbEl.addEventListener("pointercancel", function () { swipeStart = null; });
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && modal && !modal.classList.contains("is-hidden")) closeModal();
        });

      })();
    </script>
    <style is:global>
      .pw-photo-wrap {
        position: relative;
        width: 100%;
      }
      .pw-photo-card {
        position: relative;
        width: 100%;
        border: none;
        padding: 0;
        background: #fff;
        border-radius: 14px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(70,80,110,.16);
        transition: transform .22s cubic-bezier(.34,1.56,.64,1);
      }
      .pw-photo-card:hover { transform: translateY(-6px); }
      .pw-photo-card img {
        display: block;
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
      }
      .pw-photo-delete {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 2;
      }
      .pw-photo-delete__btn {
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border: 1px solid rgba(255,255,255,.76);
        border-radius: 50%;
        background: rgba(255,255,255,.86);
        color: #b45656;
        font-family: var(--font);
        font-size: 20px;
        font-weight: 650;
        line-height: 1;
        cursor: pointer;
        box-shadow: 0 8px 18px rgba(60,70,90,.2);
        -webkit-backdrop-filter: blur(6px);
        backdrop-filter: blur(6px);
        transition: background .16s ease, color .16s ease, transform .16s ease;
      }
      .pw-photo-delete__btn:hover {
        background: #fff2f2;
        color: #963f3f;
        transform: translateY(-2px) scale(1.04);
      }
      .pw-lb__delete-form {
        position: absolute;
        bottom: 24px;
        left: 50%;
        z-index: 120;
        transform: translateX(-50%);
      }
      .pw-lb__delete-form .pw-lb__delete {
        position: static;
        transform: none;
      }
    </style>
  </Fragment>
