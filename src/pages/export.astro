---
import PrototypeLayout from "../layouts/PrototypeLayout.astro";
---

<PrototypeLayout title="Export - Our Nest" current="export" backHref="/?skipCover=1#home">
  <main class="export-page">
    <section class="export-panel" aria-labelledby="exportTitle">
      <p class="export-kicker">PERSONAL ARCHIVE</p>
      <h1 id="exportTitle">Export our whole nest</h1>
      <p class="export-lead">两个人的文章、记录、照片、活动、地点、评论和待办会一起导出，不会只导出当前账号的数据。</p>

      <form id="exportForm" class="export-form">
        <label>
          <span>压缩包密码</span>
          <input id="exportPassword" type="password" minlength="12" autocomplete="new-password" required placeholder="请设置独立的强归档密码" />
        </label>
        <label>
          <span>再次输入</span>
          <input id="exportPasswordConfirm" type="password" minlength="12" autocomplete="new-password" required placeholder="再次输入，避免打错" />
        </label>
        <button id="exportButton" type="submit">生成加密归档</button>
      </form>

      <div class="export-progress" id="exportProgress" hidden>
        <div class="export-progress__track"><span id="exportProgressBar"></span></div>
        <p id="exportStatus" role="status" aria-live="polite"></p>
      </div>

      <p class="export-note">归档使用 AES-256 加密，可在 Windows 上用 7-Zip 输入密码解压。密码和解密后的内容只在当前浏览器内存中短暂存在，不会上传到 VPS。</p>
    </section>
  </main>

  <Fragment slot="scripts">
    <script type="module" src="/scripts/readable-export.js"></script>
  </Fragment>
</PrototypeLayout>

<style>
  .export-page { min-height: 100vh; padding: 130px 20px 70px; display: grid; place-items: start center; }
  .export-panel { width: min(100%, 680px); padding: 32px; border: 1px solid rgba(95,122,150,.2); border-radius: 8px; background: rgba(255,255,255,.9); box-shadow: 0 18px 50px rgba(61,79,101,.12); font-family: "Satoshi", "PingFang SC", "Microsoft YaHei", sans-serif; color: #405a70; }
  .export-kicker { margin: 0 0 8px; color: #7a9fbd; font-size: 12px; font-weight: 800; letter-spacing: .12em; }
  h1 { margin: 0; color: #304a60; font-size: 34px; line-height: 1.2; }
  .export-lead { margin: 14px 0 24px; line-height: 1.7; }
  .export-form { display: grid; gap: 14px; }
  .export-form label { display: grid; gap: 7px; font-size: 14px; font-weight: 700; }
  .export-form input { width: 100%; box-sizing: border-box; border: 1px solid rgba(95,122,150,.28); border-radius: 7px; padding: 12px 13px; background: #fff; color: #304a60; font: inherit; }
  .export-form input:focus { outline: 2px solid rgba(122,166,212,.35); border-color: #7aa6d4; }
  .export-form button { margin-top: 4px; border: 0; border-radius: 7px; padding: 13px 18px; background: #6f9fc9; color: white; font: inherit; font-weight: 800; cursor: pointer; }
  .export-form button:disabled { opacity: .6; cursor: wait; }
  .export-progress { margin-top: 22px; }
  .export-progress__track { height: 8px; overflow: hidden; border-radius: 4px; background: #e8eef4; }
  .export-progress__track span { display: block; width: 0; height: 100%; background: #79a8cf; transition: width .2s ease; }
  #exportStatus { margin: 8px 0 0; font-size: 14px; }
  .export-note { margin: 22px 0 0; padding-top: 18px; border-top: 1px solid rgba(95,122,150,.15); color: #71869a; font-size: 13px; line-height: 1.65; }
  @media (max-width: 760px) { .export-page { padding: 100px 12px 40px; } .export-panel { padding: 24px 18px; } h1 { font-size: 28px; } }
</style>
